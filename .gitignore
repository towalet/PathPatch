# Planning / internal docs
*.plan.md

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Python / Django
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg
.venv/
venv/
env/
.python-version
db.sqlite3
db.sqlite3-journal
/backend/staticfiles/
/backend/media/
/backend/.coverage
/backend/htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Vite / React
node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Docker
*.local

# Logs
*.log
logs/
!samples/*.log
!backend/apps/diagnostics/tests/fixtures/*.log
